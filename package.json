{
  "name": "skim",
  "version": "1.0.6",
  "description": "A fast, minimalist, AI-native email client for Windows",
  "license": "MIT",
  "homepage": "https://skim-tech.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikserg/skim.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "demo": "npm run demo:browser && npm run demo:record && npm run demo:encode && npm run demo:shots",
    "demo:browser": "playwright install chromium",
    "demo:dev": "vite --config demo/vite.demo.config.ts",
    "demo:build": "vite build --config demo/vite.demo.config.ts",
    "demo:record": "node demo/record.mjs",
    "demo:encode": "node demo/encode.mjs",
    "demo:shots": "node demo/screenshots.mjs"
  },
  "dependencies": {
    "@fontsource-variable/hanken-grotesk": "^5.2.0",
    "@fontsource/ibm-plex-mono": "^5.2.0",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-notification": "^2.3.1",
    "@tauri-apps/plugin-opener": "^2.5.0",
    "@tauri-apps/plugin-updater": "~2.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.9.0",
    "@tsconfig/svelte": "^5.0.5",
    "playwright": "^1.49.0",
    "svelte": "^5.45.0",
    "svelte-check": "^4.3.3",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  }
}
